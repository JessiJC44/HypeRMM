rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Global Deny
    // ===============================================================
    match /{document=**} {
      allow read, write: if false;
    }

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == "sedrayiokoraz@gmail.com" ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
      );
    }

    function isDocOwner() {
      return isSignedIn() && resource.data.userId == request.auth.uid;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    
    // Validation helper for creating documents
    function isValidKnowledgeBaseArticle(data) {
      return data.title is string && data.title.size() <= 200 &&
             data.category is string && data.category.size() <= 100 &&
             data.content is string && data.content.size() <= 50000;
    }

    // ===============================================================
    // Collection Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && 
                      incoming().role == 'user';
      allow update: if isOwner(userId) && 
                      incoming().role == existing().role &&
                      incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL', 'phoneNumber', 'lastLogin']);
      allow delete: if isAdmin();
    }

    match /devices/{deviceId} {
      allow read: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow write: if false; // Writes only via Admin SDK
    }

    match /tickets/{ticketId} {
      allow read: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && incoming().userId == request.auth.uid && 
                      incoming().title is string && incoming().title.size() <= 256;
      allow update: if (isAdmin() || (isSignedIn() && existing().userId == request.auth.uid)) &&
                      incoming().userId == existing().userId;
      allow delete: if isAdmin() || (isSignedIn() && existing().userId == request.auth.uid);
    }

    match /alerts/{alertId} {
      allow read, list: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow create: if isSignedIn() && incoming().userId == request.auth.uid;
      allow update, delete: if isAdmin() || (isSignedIn() && existing().userId == request.auth.uid);
    }

    match /kb_articles/{articleId} {
      allow read, list: if isSignedIn() && resource.data.published == true;
      allow write: if isAdmin();
    }

    match /patches/{patchId} {
      allow read, list: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow create: if isSignedIn() && incoming().userId == request.auth.uid;
      allow update, delete: if isAdmin() || (isSignedIn() && existing().userId == request.auth.uid);
    }

    match /device_heartbeats/{heartbeatId} {
      allow read, list: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow write: if false; // Read-only for users
    }

    // Default catch-all for other collections defined in blueprint but not explicitly matched
    // (Should be handled by the global deny at the top)
    
    // Commands, Logs, Enrollment Tokens, Scripts, script_runs, network_scans, results
    // are all restricted to Admin role or specific userId match via the pattern above.
    
    match /passkeys/{docId} { 
      allow read, list: if isAdmin() || isDocOwner();
      allow create: if isSignedIn() && incoming().userId == request.auth.uid;
      allow update, delete: if isAdmin() || (isSignedIn() && existing().userId == request.auth.uid);
    }
    
    match /commands/{docId} { allow read, list: if isAdmin() || isDocOwner(); }
    match /device_logs/{docId} { allow read, list: if isAdmin() || isDocOwner(); }
    match /scripts/{docId} { allow read, list: if isAdmin() || isDocOwner(); }
    match /script_runs/{docId} { allow read, list: if isAdmin() || isDocOwner(); }
    match /network_scans/{docId} { allow read, list: if isAdmin() || isDocOwner(); }
    match /network_scan_results/{docId} { allow read, list: if isAdmin() || isDocOwner(); }
    
    match /shared_scripts/{docId} {
      allow read, list: if isSignedIn();
      allow write: if isAdmin();
    }
  }
}
