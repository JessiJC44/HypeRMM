rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Global Deny
    // ===============================================================
    match /{document=**} {
      allow read, write: if false;
    }

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == "sedrayiokoraz@gmail.com" ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
      );
    }

    function isDocOwner() {
      return isSignedIn() && resource.data.userId == request.auth.uid;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // ===============================================================
    // Collection Rules
    // ===============================================================

    match /_test/{document} {
      allow read, write: if true;
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && incoming().role == 'user';
      allow update: if isOwner(userId) && 
                      incoming().role == existing().role &&
                      incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL', 'phoneNumber', 'lastLogin']);
      allow delete: if isAdmin();
    }

    match /devices/{deviceId} {
      allow read: if true; // Support server-side cleanup worker
      allow write: if false; 
    }

    match /tickets/{ticketId} {
      allow read: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && incoming().userId == request.auth.uid;
      allow update: if (isAdmin() || (isSignedIn() && existing().userId == request.auth.uid)) &&
                      incoming().userId == existing().userId;
      allow delete: if isAdmin() || (isSignedIn() && existing().userId == request.auth.uid);
    }

    match /alerts/{alertId} {
      allow read, list: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow create: if isSignedIn() && incoming().userId == request.auth.uid;
      allow update, delete: if isAdmin() || (isSignedIn() && existing().userId == request.auth.uid);
    }

    match /kb_articles/{articleId} {
      allow read, list: if isSignedIn() && resource.data.published == true;
      allow write: if isAdmin();
    }

    match /patches/{patchId} {
      allow read, list: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow create: if isSignedIn() && incoming().userId == request.auth.uid;
      allow update, delete: if isAdmin() || (isSignedIn() && existing().userId == request.auth.uid);
    }

    match /device_heartbeats/{heartbeatId} {
      allow read, list: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow write: if false;
    }

    match /passkeys/{docId} { 
      allow read, list: if isAdmin() || isDocOwner();
      allow create: if isSignedIn() && incoming().userId == request.auth.uid;
      allow update, delete: if isAdmin() || (isSignedIn() && existing().userId == request.auth.uid);
    }

    // AppCenter
    match /software_catalog/{catalogId} {
      allow read: if true; 
      allow create, update: if true; 
      allow delete: if isAdmin();
    }

    match /device_installed_software/{id} {
      allow read: if isDocOwner() || isAdmin();
      allow create, update, delete: if false;
    }

    // SNMP
    match /snmp_templates/{id} {
      allow read: if isDocOwner() || isAdmin();
      allow create: if isSignedIn() && incoming().userId == request.auth.uid;
      allow update, delete: if isAdmin() || (isSignedIn() && existing().userId == request.auth.uid);
    }

    match /snmp_devices/{id} {
      allow read: if true; // Allow SNMP worker to read devices
      allow create: if isSignedIn() && incoming().userId == request.auth.uid;
      allow update, delete: if isAdmin() || (isSignedIn() && existing().userId == request.auth.uid);
    }
    match /snmp_oid_history/{id} {
      allow read: if isDocOwner() || isAdmin();
      allow write: if false;
    }
    match /snmp_shared_templates/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // Thresholds
    match /threshold_profiles/{profileId} {
      allow read: if isDocOwner() || isAdmin();
      allow create: if isSignedIn() && incoming().userId == request.auth.uid;
      allow update, delete: if isAdmin() || (isSignedIn() && existing().userId == request.auth.uid);
      
      match /items/{itemId} {
        allow read: if get(/databases/$(database)/documents/threshold_profiles/$(profileId)).data.userId == request.auth.uid || isAdmin();
        allow write: if isAdmin() || (isSignedIn() && get(/databases/$(database)/documents/threshold_profiles/$(profileId)).data.userId == request.auth.uid);
      }
    }
    match /device_folders/{folderId} {
      allow read: if isDocOwner() || isAdmin();
      allow create: if isSignedIn() && incoming().userId == request.auth.uid;
      allow update, delete: if isAdmin() || (isSignedIn() && existing().userId == request.auth.uid);
    }

    // Automation
    match /automation_profiles/{id} {
      allow read: if isDocOwner() || isAdmin();
      allow create: if isSignedIn() && incoming().userId == request.auth.uid;
      allow update, delete: if isAdmin() || (isSignedIn() && existing().userId == request.auth.uid);
    }
    match /automation_executions/{id} {
      allow read: if isDocOwner() || isAdmin();
      allow write: if false;
    }
    match /software_bundles/{id} {
      allow read: if isDocOwner() || isAdmin();
      allow create: if isSignedIn() && incoming().userId == request.auth.uid;
      allow update, delete: if isAdmin() || (isSignedIn() && existing().userId == request.auth.uid);
    }

    // Agent Tools
    match /commands/{docId} { 
      allow read, list: if isAdmin() || isDocOwner(); 
      allow create: if true; 
    }
    match /device_logs/{docId} { allow read, list: if isAdmin() || isDocOwner(); }
    match /scripts/{docId} { allow read, list: if isAdmin() || isDocOwner(); allow create: if isSignedIn(); }
    match /script_runs/{docId} { allow read, list: if isAdmin() || isDocOwner(); }
    match /network_scans/{docId} { allow read, list: if isAdmin() || isDocOwner(); allow create: if isSignedIn(); }
    match /network_scan_results/{docId} { allow read, list: if isAdmin() || isDocOwner(); }
    
    match /shared_scripts/{docId} {
      allow read, list: if isSignedIn();
      allow write: if isAdmin();
    }
  }
}
