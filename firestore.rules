rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Global Deny
    // ===============================================================
    match /{document=**} {
      allow read, write: if false;
    }

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && (
        (request.auth.token.email == "sedrayiokoraz@gmail.com" && request.auth.token.email_verified == true) ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', 'user') == 'admin')
      );
    }

    function isDocOwner() {
      return isSignedIn() && resource.data.userId == request.auth.uid;
    }

    // Validation helpers
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    
    // For creation: check required fields and size
    function isValidCreation(required, maxSize) {
      return incoming().keys().hasAll(required) && incoming().keys().size() <= maxSize;
    }

    // For updates: check only specific fields changed
    function affectedKeys() { return request.resource.data.diff(resource.data).affectedKeys(); }

    // ===============================================================
    // Collection Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && 
                      isValidCreation(['uid', 'email'], 10) &&
                      (incoming().role == 'user' || (request.auth.token.email == "sedrayiokoraz@gmail.com" && incoming().role == 'admin'));
      allow update: if isOwner(userId) && 
                      incoming().role == existing().role &&
                      affectedKeys().hasOnly(['displayName', 'photoURL', 'phoneNumber', 'lastLogin']);
      allow delete: if isAdmin();
    }

    match /devices/{deviceId} {
      allow read: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow write: if false; // Writes only via Admin SDK
    }

    match /commands/{commandId} {
      allow read: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow write: if false; // Writes only via Admin SDK
    }

    match /device_logs/{logId} {
      allow read: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow write: if false; // Writes only via Admin SDK
    }

    match /tickets/{ticketId} {
      allow read: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow create: if isSignedIn() && incoming().userId == request.auth.uid && isValidCreation(['title', 'userId'], 15);
      allow update: if (isAdmin() || (isSignedIn() && existing().userId == request.auth.uid)) &&
                      !affectedKeys().hasAny(['userId']);
      allow delete: if isAdmin() || (isSignedIn() && existing().userId == request.auth.uid);
    }

    match /alerts/{alertId} {
      allow read: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow create: if isSignedIn() && incoming().userId == request.auth.uid;
      allow update, delete: if isAdmin() || (isSignedIn() && existing().userId == request.auth.uid);
    }

    match /sites/{siteId} {
      allow read: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow create: if isSignedIn() && incoming().userId == request.auth.uid;
      allow update, delete: if isAdmin() || (isSignedIn() && existing().userId == request.auth.uid);
    }

    match /software/{softwareId} {
      allow read: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow create: if isSignedIn() && incoming().userId == request.auth.uid;
      allow update, delete: if isAdmin() || (isSignedIn() && existing().userId == request.auth.uid);
    }

    match /patches/{patchId} {
      allow read: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow create: if isSignedIn() && incoming().userId == request.auth.uid;
      allow update, delete: if isAdmin() || (isSignedIn() && existing().userId == request.auth.uid);
    }

    match /passkeys/{docId} {
      allow read: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow create: if isSignedIn() && incoming().userId == request.auth.uid;
      allow update, delete: if isAdmin() || (isSignedIn() && existing().userId == request.auth.uid);
    }

    match /agent_enrollment_tokens/{tokenId} {
      allow read, write: if false; // Backend only
    }

    match /scripts/{scriptId} {
      allow read: if isDocOwner() || isAdmin();
      allow create, update, delete: if false; // Server only
    }

    match /script_runs/{runId} {
      allow read: if isDocOwner() || isAdmin();
      allow create, update, delete: if false; // Server only
    }

    match /shared_scripts/{scriptId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    match /network_scans/{scanId} {
      allow read: if isDocOwner() || isAdmin();
      allow create, update, delete: if false;
    }

    match /network_scan_results/{resultId} {
      allow read: if isDocOwner() || isAdmin();
      allow create, update, delete: if false;
    }
    
    // Legacy mapping if needed for older migrations
    match /agent_enrollments/{tokenHash} {
      allow read, write: if false;
    }
  }
}
