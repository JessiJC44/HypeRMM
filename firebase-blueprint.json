{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "user"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    },
    "Device": {
      "title": "Device",
      "description": "Managed device information",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "type": { "type": "string", "enum": ["workstation", "server", "laptop", "mobile"] },
        "os": { "type": "string" },
        "status": { "type": "string", "enum": ["online", "offline", "warning"] },
        "ip": { "type": "string" },
        "customer": { "type": "string" },
        "lastSeen": { "type": "string", "format": "date-time" },
        "fluxId": { "type": "string" }
      },
      "required": ["name", "type", "status"]
    },
    "Ticket": {
      "title": "Ticket",
      "description": "Support ticket information",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "customer": { "type": "string" },
        "status": { "type": "string", "enum": ["open", "pending", "resolved", "closed"] },
        "priority": { "type": "string", "enum": ["low", "medium", "high", "critical"] },
        "assignedTo": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "customer", "status", "priority"]
    },
    "Alert": {
      "title": "Alert",
      "description": "System alert information",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "deviceId": { "type": "string" },
        "deviceName": { "type": "string" },
        "message": { "type": "string" },
        "severity": { "type": "string", "enum": ["info", "warning", "critical"] },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["message", "severity", "timestamp"]
    },
    "Site": {
      "title": "Site",
      "description": "Customer site information",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "address": { "type": "string" },
        "contactName": { "type": "string" },
        "contactEmail": { "type": "string" },
        "deviceCount": { "type": "number" },
        "status": { "type": "string", "enum": ["active", "inactive"] }
      },
      "required": ["name"]
    },
    "Software": {
      "title": "Software",
      "description": "Software inventory item",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "version": { "type": "string" },
        "publisher": { "type": "string" },
        "installCount": { "type": "number" }
      },
      "required": ["name", "version"]
    },
    "Patch": {
      "title": "Patch",
      "description": "Software patch information",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "severity": { "type": "string", "enum": ["low", "medium", "high", "critical"] },
        "status": { "type": "string", "enum": ["pending", "installed", "failed"] },
        "releaseDate": { "type": "string", "format": "date" }
      },
      "required": ["name", "severity", "status"]
    },
    "Command": {
      "title": "Command",
      "description": "Remote execution command",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "deviceId": { "type": "string" },
        "userId": { "type": "string" },
        "type": { "type": "string" },
        "payload": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "completed", "failed"] },
        "result": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "completedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["deviceId", "userId", "type", "status"]
    },
    "DeviceLog": {
      "title": "DeviceLog",
      "description": "Log entries from devices",
      "type": "object",
      "properties": {
        "deviceId": { "type": "string" },
        "userId": { "type": "string" },
        "level": { "type": "string", "enum": ["info", "warning", "error"] },
        "message": { "type": "string" },
        "source": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["deviceId", "userId", "level", "message"]
    },
    "AgentEnrollmentToken": {
      "title": "AgentEnrollmentToken",
      "description": "Enrollment token for new agents",
      "type": "object",
      "properties": {
        "tokenHash": { "type": "string" },
        "userId": { "type": "string" },
        "used": { "type": "boolean" },
        "expiresAt": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["tokenHash", "userId", "used", "expiresAt"]
    },
    "Script": {
      "title": "Script",
      "description": "A reusable PowerShell, Bash, or Python script with variables.",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "Owner of the script (null for shared scripts)" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "category": { "type": "string" },
        "language": { "type": "string", "enum": ["powershell", "bash", "python"] },
        "fileExtension": { "type": "string" },
        "content": { "type": "string" },
        "variables": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "defaultValue": { "type": "string" },
              "description": { "type": "string" }
            }
          }
        },
        "targetOs": { "type": "array", "items": { "type": "string", "enum": ["windows", "mac", "linux"] } },
        "aiCopilotEnabled": { "type": "boolean" },
        "isTemplate": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "lastRunAt": { "type": "string", "format": "date-time" },
        "runCount": { "type": "number" }
      },
      "required": ["name", "language", "content"]
    },
    "ScriptRun": {
      "title": "ScriptRun",
      "description": "A log of a script execution on a device.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "scriptId": { "type": "string" },
        "deviceId": { "type": "string" },
        "variableValues": { "type": "object" },
        "startedAt": { "type": "string", "format": "date-time" },
        "completedAt": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["pending", "running", "success", "failed", "timeout"] },
        "output": { "type": "string" },
        "exitCode": { "type": "number" }
      },
      "required": ["userId", "scriptId", "deviceId", "status", "startedAt"]
    },
    "NetworkScan": {
      "title": "NetworkScan",
      "description": "A local network scan session performed by a proxy agent.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "proxyAgentId": { "type": "string" },
        "proxyAgentName": { "type": "string" },
        "siteId": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "running", "completed", "failed", "cancelled"] },
        "subnet": { "type": "string" },
        "scanTypes": { "type": "array", "items": { "type": "string", "enum": ["ping", "arp", "mdns", "portscan"] } },
        "startedAt": { "type": "string", "format": "date-time" },
        "completedAt": { "type": "string", "format": "date-time" },
        "devicesFound": { "type": "number" },
        "error": { "type": "string" },
        "createdBy": { "type": "string" }
      },
      "required": ["userId", "proxyAgentId", "status", "startedAt"]
    },
    "NetworkScanResult": {
      "title": "NetworkScanResult",
      "description": "Individual device discovered during a network scan.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "scanId": { "type": "string" },
        "ipAddress": { "type": "string" },
        "macAddress": { "type": "string" },
        "hostname": { "type": "string" },
        "osGuess": { "type": "string" },
        "openPorts": { "type": "array", "items": { "type": "number" } },
        "deviceType": { "type": "string", "enum": ["computer", "printer", "router", "switch", "iot", "unknown"] },
        "vendor": { "type": "string" },
        "responseTimeMs": { "type": "number" },
        "isManaged": { "type": "boolean" },
        "discoveredAt": { "type": "string", "format": "date-time" },
        "invitationSent": { "type": "boolean" },
        "invitationSentAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "scanId", "ipAddress", "isManaged", "discoveredAt"]
    },
    "KnowledgeBaseArticle": {
      "title": "KnowledgeBaseArticle",
      "description": "Internal help article",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "category": { "type": "string" },
        "content": { "type": "string" },
        "published": { "type": "boolean" },
        "author": { "type": "string" },
        "views": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "category", "content", "published"]
    },
    "DeviceHeartbeat": {
      "title": "DeviceHeartbeat",
      "description": "Individual performance metrics heartbeat from a device",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "deviceId": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "cpu": { "type": "number" },
        "ram": { "type": "number", "description": "RAM usage percentage" },
        "diskUsed": { "type": "number" },
        "diskTotal": { "type": "number" },
        "networkRx": { "type": "number" },
        "networkTx": { "type": "number" }
      },
      "required": ["userId", "deviceId", "timestamp"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/devices/{deviceId}": {
      "schema": "Device",
      "description": "Managed devices"
    },
    "/tickets/{ticketId}": {
      "schema": "Ticket",
      "description": "Support tickets"
    },
    "/alerts/{alertId}": {
      "schema": "Alert",
      "description": "System alerts"
    },
    "/sites/{siteId}": {
      "schema": "Site",
      "description": "Customer sites"
    },
    "/software/{softwareId}": {
      "schema": "Software",
      "description": "Software inventory"
    },
    "/patches/{patchId}": {
      "schema": "Patch",
      "description": "Software patches"
    },
    "/commands/{commandId}": {
      "schema": "Command",
      "description": "Agent commands"
    },
    "/device_logs/{logId}": {
      "schema": "DeviceLog",
      "description": "Device activity logs"
    },
    "/agent_enrollment_tokens/{tokenId}": {
      "schema": "AgentEnrollmentToken",
      "description": "Secure enrollment tokens"
    },
    "/scripts/{scriptId}": {
      "schema": "Script",
      "description": "User script library"
    },
    "/script_runs/{runId}": {
      "schema": "ScriptRun",
      "description": "History of script executions"
    },
    "/shared_scripts/{scriptId}": {
      "schema": "Script",
      "description": "Community shared script library (Read Only for non-admins)"
    },
    "/network_scans/{scanId}": {
      "schema": "NetworkScan",
      "description": "Network discovery scans"
    },
    "/network_scan_results/{resultId}": {
      "schema": "NetworkScanResult",
      "description": "Devices found in network scans"
    },
    "/kb_articles/{articleId}": {
      "schema": "KnowledgeBaseArticle",
      "description": "Knowledge Base help articles"
    },
    "/device_heartbeats/{heartbeatId}": {
      "schema": "DeviceHeartbeat",
      "description": "Near real-time performance metrics"
    }
  }
}
